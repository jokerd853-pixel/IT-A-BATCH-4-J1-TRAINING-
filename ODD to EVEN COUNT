import java.util.*;
class Main {
    public static void main(String[] args) {
        int sum = 0;
       
        Scanner ar = new Scanner(System.in);
        int n = ar.nextInt();
        int []a = new int[n];
        for(int i =0;i<n;i++){
            a[i]=ar.nextInt();
        }
        for(int i=0;i<n-1;i++){
         if(a[i]%2!=0 && a[i+1]%2==0)
         sum+=1;
        }
        System.out.println(sum);
    
    }
}
