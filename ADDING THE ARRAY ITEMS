import java.util.*;
class Main {
    public static void main(String[] args) {
        int sum = 0;
        Scanner ar = new Scanner(System.in);
        int n = ar.nextInt();
        int []a = new int[n];
        for(int i =0;i<n;i++){
            a[i]=ar.nextInt();
            sum+=a[i];
        }
        System.out.println(sum);
    }
}
